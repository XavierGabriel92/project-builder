{
  "name": "pi-project-builder",
  "version": "0.1.0",
  "description": "Pi extension: declarative generic flow engine for multi-step feature building",
  "author": "",
  "license": "MIT",
  "type": "module",
  "bin": {
    "pi-project-builder": "install.mjs"
  },
  "files": [
    "src/**/*.ts",
    "*.mjs",
    "scripts/",
    "agents/",
    "flows/",
    "skills/**/*",
    "README.md"
  ],
  "keywords": ["pi-package", "pi", "pi-coding-agent", "flow-engine", "project-builder"],
  "scripts": {
    "test": "node --experimental-strip-types --test test/unit/*.test.ts",
    "validate": "node --experimental-strip-types scripts/validate.mjs",
    "scaffold:agent": "node scripts/scaffold-agent.mjs"
  },
  "pi": {
    "extensions": ["./src/ui/index.ts"]
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-agent-core": { "optional": true }
  },
  "dependencies": {
    "typebox": "^1.1.24"
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0"
  }
}
